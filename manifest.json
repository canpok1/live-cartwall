{
  "manifest_version": 3,
  "name": "Tab Audio Console",
  "version": "1.0.0",
  "description": "画面共有中のタブの中でBGM・効果音を再生する操作卓。操作パネルは別ウィンドウなので、共有画面には映りません。",
  "minimum_chrome_version": "116",

  "permissions": [
    "scripting",
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "操作パネルを開く"
  },

  "commands": {
    "cue-1": {
      "suggested_key": { "default": "Alt+Shift+1", "mac": "Alt+Shift+1" },
      "description": "Q1 を再生"
    },
    "cue-2": {
      "suggested_key": { "default": "Alt+Shift+2", "mac": "Alt+Shift+2" },
      "description": "Q2 を再生"
    },
    "cue-3": {
      "suggested_key": { "default": "Alt+Shift+3", "mac": "Alt+Shift+3" },
      "description": "Q3 を再生"
    },
    "cue-4": {
      "description": "Q4 を再生（ショートカットは chrome://extensions/shortcuts で割当）"
    },
    "cue-5": {
      "description": "Q5 を再生（ショートカットは chrome://extensions/shortcuts で割当）"
    },
    "cue-6": {
      "description": "Q6 を再生（ショートカットは chrome://extensions/shortcuts で割当）"
    },
    "all-stop": {
      "suggested_key": { "default": "Alt+Shift+0", "mac": "Alt+Shift+0" },
      "description": "全停止"
    }
  }
}
